{
  "manifest_version": 3,
  "name": "StellarSync Plugin",
  "version": "0.1.1",
  "description": "Capture page links and social posts into StellarSync, with a LinkedIn exporter tab.",
  "icons": {
    "16": "icons/stellarsync-16.png",
    "32": "icons/stellarsync-32.png",
    "48": "icons/stellarsync-48.png",
    "128": "icons/stellarsync-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StellarSync Plugin",
    "default_icon": {
      "16": "icons/stellarsync-16.png",
      "32": "icons/stellarsync-32.png",
      "48": "icons/stellarsync-48.png",
      "128": "icons/stellarsync-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://media.licdn.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
